# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
# pnpm-lock.yaml
public/uploads
.claude
.spec-workflow
.ace-tool/
.env.local
.codex
.worktrees
.vscode
.gemini
.opencode
.npm-cache

# local agent and workspace state
/.cursor/
/.workbuddy/
/outputs/
/_tmp_*

# kilo / kilocode tooling
.kilo
.kilocode

# desktop client build artifacts
/desktop/frontend/node_modules
/desktop/frontend/dist
/desktop/frontend/package.json.md5
/desktop/build/bin
/desktop/.tmp/
/desktop/**/*.go.[0-9]*
*.bak

# flutter mobile client
/flutter/
/flutter/.dart_tool/
/flutter/build/
/flutter/.flutter-plugins
/flutter/.flutter-plugins-dependencies
/flutter/.packages
/flutter/**/GeneratedPluginRegistrant.*

# workspace package dependency links
/packages/*/node_modules/
